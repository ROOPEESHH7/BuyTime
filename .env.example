# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Pooled connection for serverless (use in application)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/buytime?sslmode=require"

# Direct connection for migrations (Neon dashboard → Connection Details)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/buytime?sslmode=require"

# ─── Auth.js ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# OAuth providers (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="BuyTime"
